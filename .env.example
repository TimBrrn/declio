# Telnyx
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_PHONE_NUMBER=+33xxxxxxxxx
TELNYX_SIP_CONNECTION_ID=your_sip_connection_id

# Deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id

# Google Calendar
GOOGLE_CALENDAR_ID=your_calendar_id
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service_account.json

# Database
DATABASE_URL=sqlite:///declio.db

# Auth (Better Stack)
BETTERSTACK_API_TOKEN=your_betterstack_api_token

# Admin login
ADMIN_EMAIL=admin@declio.fr
ADMIN_PASSWORD=your_admin_password

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
STREAM_BASE_URL=wss://your-domain.com
CORS_ORIGINS=http://localhost:5173
